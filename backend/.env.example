# APPLICATION
ENVIRONMENT="development"
DEBUG=false

# STORAGE
# DATA_DIR is where .md files and the SQLite index live.
# Default: ./data (relative to where uvicorn is started, i.e. /app/data in Docker)
DATA_DIR="./data"
# DATABASE_URL is auto-derived from DATA_DIR if not set:
#   sqlite:///./data/.leaf.db
# You can override it, e.g. to use an absolute path:
# DATABASE_URL="sqlite:////absolute/path/to/.leaf.db"

# MIDDLEWARE
ALLOWED_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'
