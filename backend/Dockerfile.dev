FROM python:3.11-bookworm as builder

# python:3.11-bookworm already has curl + ca-certificates; install poetry directly.
RUN POETRY_VERSION=2.3.2 curl -fsSL --connect-timeout 30 --max-time 600 https://install.python-poetry.org | python3 - \
    && /root/.local/bin/poetry --version

ENV PATH="/root/.local/bin:${PATH}" \
    POETRY_NO_INTERACTION=1 \
    POETRY_VIRTUALENVS_IN_PROJECT=1 \
    POETRY_VIRTUALENVS_CREATE=1 \
    POETRY_CACHE_DIR=/tmp/poetry_cache \
    PIP_DEFAULT_TIMEOUT=120 \
    POETRY_INSTALLER_PARALLEL=false

WORKDIR /app

# Copy poetry configuration files
COPY pyproject.toml poetry.lock* ./

# -v so build logs show progress (first install can take several minutes; looks “stuck” otherwise)
RUN poetry --version && poetry install --no-root --only main -v

# Copy application code
COPY . .
RUN sed -i 's/\r//' wait-for-it.sh && chmod +x wait-for-it.sh

# Final stage
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy virtual environment from builder
COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /app /app

# Set environment variables
ENV PATH="/app/.venv/bin:$PATH"

# Expose the port your FastAPI app runs on
EXPOSE 8000

# Command to run the application
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]